{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "全球电商日历",
  "mainBinaryName": "全球电商日历",
  "version": "2.0.0",
  "identifier": "com.globalecom.calendar",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "全球电商日历",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "shadow": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": []
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "msi", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "wix": {
        "language": ["zh-CN"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"]
      }
    },
    "category": "Productivity",
    "shortDescription": "全球节日活动与采购指南",
    "longDescription": "根据日期和地区自动生成节日、大型活动、气候和采购建议的跨境电商工具"
  }
}
